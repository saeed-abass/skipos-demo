generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id              String              @id @default(cuid())
  name            String
  company_number  String?
  ea_registration String?
  address         String
  postcode        String
  phone           String
  email           String
  logo_url        String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  customers       Customer[]
  jobs            Job[]
  skips           Skip[]
  users           User[]
  wtns            WasteTransferNote[]

  @@map("companies")
}

model User {
  id         String   @id @default(cuid())
  company_id String
  email      String   @unique
  full_name  String
  role       Role     @default(OFFICE)
  avatar_url String?
  created_at DateTime @default(now())
  jobs       Job[]    @relation("DriverJobs")
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("users")
}

model Customer {
  id         String   @id @default(cuid())
  company_id String
  name       String
  phone      String
  email      String?
  address    String
  postcode   String
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  jobs       Job[]

  @@map("customers")
}

model Job {
  id                  String             @id @default(cuid())
  company_id          String
  customer_id         String
  driver_id           String?
  skip_id             String?
  job_type            JobType
  status              JobStatus          @default(PENDING)
  skip_size           SkipSize
  delivery_address    String
  delivery_postcode   String
  scheduled_date      DateTime?
  scheduled_time_slot String?
  permit_required     Boolean            @default(false)
  permit_number       String?
  price               Decimal?
  notes               String?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  job_number          String?
  company             Company            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  customer            Customer           @relation(fields: [customer_id], references: [id])
  driver              User?              @relation("DriverJobs", fields: [driver_id], references: [id])
  skip                Skip?              @relation(fields: [skip_id], references: [id])
  wtn                 WasteTransferNote?

  @@map("jobs")
}

model WasteTransferNote {
  id                    String    @id @default(cuid())
  company_id            String
  job_id                String    @unique
  wtn_number            String    @unique
  waste_description     String
  ewc_code              String
  quantity_kg           Decimal?
  container_type        String    @default("Skip")
  collection_address    String
  collection_postcode   String
  disposal_site_name    String?
  disposal_site_address String?
  carrier_name          String
  carrier_ea_number     String
  consignee_name        String?
  consignee_address     String?
  transfer_date         DateTime
  status                WTNStatus @default(DRAFT)
  customer_signature    String?
  customer_signed_at    DateTime?
  defra_submission_id   String?
  defra_submitted_at    DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  company               Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  job                   Job       @relation(fields: [job_id], references: [id])

  @@map("waste_transfer_notes")
}

model Skip {
  id          String     @id @default(cuid())
  company_id  String
  skip_number String
  size        SkipSize
  condition   Condition  @default(GOOD)
  status      SkipStatus @default(IN_YARD)
  notes       String?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  jobs        Job[]
  company     Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, skip_number])
  @@map("skips")
}

enum Role {
  ADMIN  @map("admin")
  OFFICE @map("office")
  DRIVER @map("driver")
}

enum JobType {
  DELIVERY      @map("delivery")
  COLLECTION    @map("collection")
  EXCHANGE      @map("exchange")
  WAIT_AND_LOAD @map("wait_and_load")
}

enum JobStatus {
  PENDING     @map("pending")
  SCHEDULED   @map("scheduled")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")
}

enum SkipSize {
  TWO_YARD      @map("two_yard")
  FOUR_YARD     @map("four_yard")
  SIX_YARD      @map("six_yard")
  EIGHT_YARD    @map("eight_yard")
  TWELVE_YARD   @map("twelve_yard")
  FOURTEEN_YARD @map("fourteen_yard")
  SIXTEEN_YARD  @map("sixteen_yard")
  TWENTY_YARD   @map("twenty_yard")
}

enum WTNStatus {
  DRAFT     @map("draft")
  SIGNED    @map("signed")
  SUBMITTED @map("submitted")
  ACCEPTED  @map("accepted")
  REJECTED  @map("rejected")
}

enum Condition {
  GOOD @map("good")
  FAIR @map("fair")
  POOR @map("poor")
}

enum SkipStatus {
  IN_YARD @map("in_yard")
  ON_SITE @map("on_site")
  AT_TIP  @map("at_tip")
}
